NODE_ENV=development
PORT=4020
# PostgreSQL على VPS: افتح نفق SSH أولاً (محلي 5433 → 127.0.0.1:5432 على الخادم). لا تستخدم 5432 على Windows لهذا الغرض.
# مثال (استبدل كلمة المرور): postgresql://erp_user:YOUR_PASSWORD@127.0.0.1:5433/fabric_erp?sslmode=disable
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
APP_BASE_URL=https://clotexerp.org
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# مطلوب لتجزئة مفاتيح التفعيل (واجهة API و npm run activation:generate).
ACTIVATION_KEY_PEPPER=
ACTIVATION_GENERATE_DEV_KEYS=false
ACTIVATION_REQUIRE_ACTIVE=true

# كلمة مرور مستخدم التهيئة (admin). الإنتاج: مطلوبة. التطوير بدون قيمة: admin123 (مع تحذير في السجل فقط).
SEED_ADMIN_PASSWORD=
